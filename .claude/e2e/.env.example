# Copy to .env and fill in your GitHub PAT
# This file is gitignored - never commit real tokens

# Your GitHub PAT (required for E2E testing)
# public_repo is enough for the smoke test and the full GOAT path
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kitchen auth token (auto-generated by 'make e2e-up' if not set)
# AUTH_TOKEN=<will be generated>

# Kitchen URL (auto-populated by 'make e2e-up')
# KITCHEN_URL=http://127.0.0.1:18280

# External callback URL for Brisket stagers (auto-populated by 'make e2e-up')
# KITCHEN_EXTERNAL_URL=https://xxx.trycloudflare.com
